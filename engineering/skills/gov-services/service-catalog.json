  "services": {
    "kra": {
      "name": "Kenya Revenue Authority (KRA)",
      "name_sw": "Mamlaka ya Mapato ya Kenya (KRA)",
      "icon": "🏛️",
      "sub_services": {
        "pin_registration": {
          "name": "KRA PIN Registration",
          "name_sw": "Usajili wa KRA PIN",
          "fee": 150,
          "processing_time": "Immediate (online)",
          "description": "Register for a new KRA PIN number for tax purposes",
          "description_sw": "Jisajili kwa KRA PIN mpya ya kulipa ushuru",
          "required_documents": [
            "National ID or Passport",
            "Phone number",
            "Email address (optional)"
          ],
          "required_documents_sw": [
            "Kitambulisho cha Taifa au Passport",
            "Nambari ya simu",
            "Barua pepe (si lazima)"
          ],
          "fields": [
            {
              "name": "full_name",
              "label": "Full Name (as on ID)",
              "label_sw": "Jina Kamili (kama kwenye kitambulisho)",
              "type": "text",
              "required": true
            },
            {
              "name": "id_number",
              "label": "National ID Number",
              "label_sw": "Nambari ya Kitambulisho",
              "type": "id_number",
              "pattern": "^\\d{8}$",
              "example": "12345678",
              "required": true
            },
            {
              "name": "date_of_birth",
              "label": "Date of Birth",
              "label_sw": "Tarehe ya Kuzaliwa",
              "type": "date",
              "required": true
            },
            {
              "name": "phone_number",
              "label": "Phone Number",
              "label_sw": "Nambari ya Simu",
              "type": "phone",
              "pattern": "^0[17]\\d{8}$",
              "example": "0712345678",
              "required": true
            },
            {
              "name": "email",
              "label": "Email Address",
              "label_sw": "Barua Pepe",
              "type": "email",
              "required": false
            },
            {
              "name": "physical_address",
              "label": "Physical Address",
              "label_sw": "Anwani ya Makazi",
              "type": "text",
              "required": true
            },
            {
              "name": "tax_obligation",
              "label": "Tax Obligation Type",
              "label_sw": "Aina ya Ushuru",
              "type": "select",
              "options": ["Employment Income", "Business Income", "Rental Income", "Other"],
              "required": true
            }
          ],
          "steps": [
            "Go to https://itax.kra.go.ke",
            "Click 'New PIN Registration'",
            "Select 'Individual' as taxpayer type",
            "Fill in your personal details exactly as on your ID",
            "Upload a copy of your National ID",
            "Submit the application",
            "Your KRA PIN will be sent to your phone and email"
          ],
          "steps_sw": [
            "Nenda https://itax.kra.go.ke",
            "Bofya 'New PIN Registration'",
            "Chagua 'Individual' kama aina ya mlipa ushuru",
            "Jaza maelezo yako ya kibinafsi sawa na kwenye kitambulisho chako",
            "Pakia nakala ya Kitambulisho chako cha Taifa",
            "Wasilisha ombi lako",
            "KRA PIN yako itatumwa kwenye simu yako na barua pepe"
          ]
        },
        "pin_retrieval": {
          "name": "KRA PIN Retrieval",
          "name_sw": "Kupata KRA PIN Ulilopotea",
          "fee": 150,
          "processing_time": "Immediate",
          "description": "Retrieve your existing KRA PIN number",
          "description_sw": "Pata nambari yako ya KRA PIN uliyopotea",
          "required_documents": [
            "National ID or Passport",
            "Phone number (as registered)"
          ],
          "fields": [
            {
              "name": "full_name",
              "label": "Full Name",
              "label_sw": "Jina Kamili",
              "type": "text",
              "required": true
            },
            {
              "name": "id_number",
              "label": "National ID Number",
              "label_sw": "Nambari ya Kitambulisho",
              "type": "id_number",
              "pattern": "^\\d{8}$",
              "required": true
            },
            {
              "name": "phone_number",
              "label": "Phone Number (as registered)",
              "label_sw": "Nambari ya Simu (iliyosajiliwa)",
              "type": "phone",
              "pattern": "^0[17]\\d{8}$",
              "required": true
            }
          ],
          "steps": [
            "Go to https://itax.kra.go.ke",
            "Click 'Forgot PIN'",
            "Enter your National ID number",
            "Verify via OTP sent to your registered phone",
            "Your KRA PIN will be displayed and sent to your phone"
          ]
        },
        "returns_filing": {
          "name": "KRA Tax Returns Filing",
          "name_sw": "Kujaza Ripoti ya Ushuru",
          "fee": 200,
          "processing_time": "1-3 business days",
          "description": "File your annual tax returns with KRA",
          "description_sw": "Jaza ripoti yako ya ushuru ya mwaka na KRA",
          "required_documents": [
            "KRA PIN",
            "National ID",
            "P9 Form (for employed)",
            "Business records (for self-employed)",
            "Phone number"
          ],
          "fields": [
            {
              "name": "kra_pin",
              "label": "KRA PIN",
              "label_sw": "KRA PIN",
              "type": "kra_pin",
              "pattern": "^[A-Z]\\d{9}[A-Z]$",
              "example": "A123456789B",
              "required": true
            },
            {
              "name": "id_number",
              "label": "National ID Number",
              "label_sw": "Nambari ya Kitambulisho",
              "type": "id_number",
              "pattern": "^\\d{8}$",
              "required": true
            },
            {
              "name": "tax_year",
              "label": "Tax Year",
              "label_sw": "Mwaka wa Ushuru",
              "type": "select",
              "options": ["2025", "2024", "2023"],
              "required": true
            },
            {
              "name": "employment_status",
              "label": "Employment Status",
              "label_sw": "Hali ya Ajira",
              "type": "select",
              "options": ["Employed", "Self-Employed", "Both", "Unemployed"],
              "required": true
            },
            {
              "name": "gross_income",
              "label": "Gross Annual Income (KES)",
              "label_sw": "Mapato ya Mwaka (KES)",
              "type": "number",
              "required": true
            }
          ]
        }
      }
    },
