# Aego Cyber Cafe Server — Environment Variables
# Copy to /opt/aego/.env and fill in real values

# ── Ollama LLM ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4:4b
OLLAMA_FALLBACK_MODEL=qwen3.5:3b
OLLAMA_TIMEOUT=60

# ── WhatsApp Business Cloud API ───────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=aego_verify_token

# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_TOKEN=

# ── M-Pesa Daraja API ────────────────────────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_ENV=sandbox

# ── Admin Dashboard ───────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_THIS_PASSWORD

# ── Directories ───────────────────────────────────────────────
DATA_DIR=/opt/aego/data
OUTPUT_DIR=/opt/aego/output

# ── Server ────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
LOG_LEVEL=info

# ── Session ───────────────────────────────────────────────────
SESSION_TTL_MINUTES=30

# ── Queue ─────────────────────────────────────────────────────
QUEUE_TIMEOUT=60
QUEUE_MAX_RETRIES=1
